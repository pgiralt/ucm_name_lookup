# Docker Compose environment variables.
# Copy this file to .env and adjust for your environment:
#
#   cp .env.example .env
#
# The container must run as the UID/GID that owns the TLS private key
# (server.key is chmod 600). Use `id -u` and `id -g` on your deployment
# server to find the correct values.
DOCKER_UID=1000
DOCKER_GID=1000
